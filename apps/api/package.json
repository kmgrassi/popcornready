{
  "name": "@popcorn/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "storage:smoke": "tsx scripts/storage-smoke.ts",
    "smoke:tool-calls": "tsx scripts/orchestrator-tool-call-smoke.ts",
    "test:tools": "tsx scripts/tool-tests.ts",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@aws-sdk/client-cloudfront": "^3.1066.0",
    "@aws-sdk/client-s3": "^3.1066.0",
    "@aws-sdk/cloudfront-signer": "^3.1064.0",
    "@aws-sdk/s3-request-presigner": "^3.1066.0",
    "@google/genai": "^2.6.0",
    "@popcorn/agent": "workspace:*",
    "@popcorn/eval": "workspace:*",
    "@popcorn/llm": "workspace:*",
    "@popcorn/renderer": "workspace:*",
    "@popcorn/shared": "workspace:*",
    "@popcorn/timeline": "workspace:*",
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@supabase/supabase-js": "^2.107.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "openai": "^4.104.0",
    "remotion": "^4.0.0",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "typescript": "^5.6.3"
  }
}
