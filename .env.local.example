# Copy to .env.local and fill in your key.

# Agent API auth mode.
#   "local"    — resolves every /api/v1 request to a deterministic dev workspace,
#                no token required.
#   "supabase" — verifies a Supabase bearer token; unauthenticated requests are
#                rejected (use this in production).
#   "hybrid"   — verifies the token when present (real user + workspace, like
#                production) and falls back to the local dev identity when absent.
#                Handy for local dev: logging in behaves like prod, but the
#                dashboard still works without logging in.
AUTH_MODE=hybrid

# Persistence backend for the agent API. "local" uses the JSON file store under
# .local/; "supabase" routes the foundation store (workspaces/projects/briefs/
# assets/idempotency) through Postgres. Requires the migration in
# supabase/migrations to be pushed and SUPABASE_SERVICE_ROLE_KEY set below.
DB_BACKEND=local

# Asset byte storage. "local" keeps today's .local/media behavior. "s3" uses
# the two-bucket S3/CloudFront delivery layer and is dark until AWS/Railway env
# values are provisioned.
STORAGE_BACKEND=local
# Optional local override; defaults to POPCORN_READY_LOCAL_DIR/media or .local/media.
# STORAGE_LOCAL_DIR=.local/media
# Local MinIO test rig:
# docker compose -f docker-compose.minio.yml up -d
# STORAGE_BACKEND=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_ENDPOINT_URL_S3=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BUCKET=assets-public
# S3_PRIVATE_BUCKET=assets-private
# S3_PUBLIC_URL_BASE=http://localhost:9000/assets-public
# Production/staging S3 + CloudFront:
# S3_PUBLIC_BUCKET=assets-public
# S3_PRIVATE_BUCKET=assets-private
# S3_PUBLIC_URL_BASE=https://cdn.example.com
# CF_SIGN_KEY_PAIR_ID=your_cloudfront_key_pair_id
# CF_SIGN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Supabase. The browser (Vite SPA) reads the PUBLIC values via VITE_* — WITHOUT
# these, the web shows "Supabase login is not configured." The server (API) reads
# SUPABASE_URL + SUPABASE_ANON_KEY; the service_role key (server-only, never
# exposed to the client) powers the DB-backed store and bypasses RLS. Find the
# keys in Project Settings -> API. (Both apps load this file from the repo root.)

# Web / browser auth (VITE_* are the only client-exposed vars).
# VITE_SUPABASE_ENV selects which pair below to use: default | dev | prod.
VITE_SUPABASE_ENV=default
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
# Optional per-environment overrides (used when VITE_SUPABASE_ENV=dev|prod):
# VITE_SUPABASE_DEV_URL=https://your-dev-project.supabase.co
# VITE_SUPABASE_DEV_ANON_KEY=your_dev_anon_key
# VITE_SUPABASE_PROD_URL=https://your-prod-project.supabase.co
# VITE_SUPABASE_PROD_ANON_KEY=your_prod_anon_key
# Optional: point the web's /api proxy at a non-default API port.
# VITE_API_URL=http://localhost:4000

# Server (API) — same project as VITE_SUPABASE_URL above.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Which LLM provider runs the agent "brain" (planning, critique, revision, and
# the orchestrator tool loop). Default "openai". Set "anthropic" to use Claude.
# The selected provider's API key above must be set.
LLM_PROVIDER=openai
# Model per provider (override the defaults). OpenAI defaults to gpt-5; if your
# key lacks gpt-5 access, set e.g. gpt-4o. Anthropic falls back to lib/anthropic MODEL.
OPENAI_MODEL=gpt-5
# ANTHROPIC_MODEL=claude-opus-4-7
# Cheaper "fast" model used automatically for low-reasoning calls (minimal/low
# effort: prompt cleanup, narration rewrite). Set to your primary model to disable.
OPENAI_FAST_MODEL=gpt-5-mini
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
NVIDIA_API_KEY=your_nvidia_api_catalog_key_here
NVIDIA_VIDEO_GENERATION_BASE_URL=https://ai.api.nvidia.com/v1/genai
NVIDIA_VIDEO_GENERATION_MODEL=nvidia/cosmos3-nano
# Optional: default voice used by ElevenLabs speech/dialogue helpers.
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# One-shot generation mode (landing-page "create a video" flow). "on" generates
# a real video clip per beat (higher cost + latency, but a true moving video);
# set to "off" as a kill switch to fall back to fast still-frame generation
# under heavy traffic. Defaults to on. Requires OPENAI_API_KEY (Sora) or
# GEMINI_API_KEY (Veo) for video; without either it uses still frames.
ONESHOT_VIDEO=on
