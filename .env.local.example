# Copy to .env.local and fill in your key.

# Agent API auth mode. "local" resolves every /api/v1 request to a deterministic
# dev workspace with no API key. Hosted key-based auth is not implemented yet.
AUTH_MODE=local

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
NVIDIA_API_KEY=your_nvidia_api_catalog_key_here
NVIDIA_VIDEO_GENERATION_BASE_URL=https://ai.api.nvidia.com/v1/genai
NVIDIA_VIDEO_GENERATION_MODEL=nvidia/cosmos3-nano
# Optional: default voice used by ElevenLabs speech/dialogue helpers.
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# One-shot generation mode (landing-page "create a video" flow). "on" generates
# a real video clip per beat (higher cost + latency, but a true moving video);
# set to "off" as a kill switch to fall back to fast still-frame generation
# under heavy traffic. Defaults to on. Requires OPENAI_API_KEY (Sora) or
# GEMINI_API_KEY (Veo) for video; without either it uses still frames.
ONESHOT_VIDEO=on
